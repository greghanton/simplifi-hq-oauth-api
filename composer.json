{
  "name": "greghanton/simplifi-hq-oauth-api",
  "description": "OAuth2 client and request dispatcher for the Joy Pilot API tier",
  "license": "proprietary",
  "authors": [
    {
      "name": "Greg Hanton"
    }
  ],
  "autoload": {
    "psr-4": {
      "SimplifiApi\\": "src"
    },
    "files": [
      "src/helpers.php"
    ]
  },
  "require": {
    "php": "^8.1",
    "php-curl-class/php-curl-class": "^13.0.0",
    "guzzlehttp/guzzle": "^7.0",
    "guzzlehttp/promises": "^2.0",
    "ext-json": "*",
    "ext-curl": "*"
  },
  "require-dev": {
    "laravel/pint": "^1.29",
    "pestphp/pest": "^4.0.0",
    "phpunit/phpunit": "^12.0.0",
    "phpstan/phpstan": "^2.0.0"
  },
  "scripts": {
    "lint": "vendor/bin/pint",
    "lint:check": "vendor/bin/pint --test"
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  }
}
